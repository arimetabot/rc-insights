# RevenueCat Charts API
# Get your API key from: https://app.revenuecat.com/settings/api-keys
RC_API_KEY=sk_your_api_key_here

# Your RevenueCat project ID
# Find it in: https://app.revenuecat.com/projects
RC_PROJECT_ID=proj_your_project_id

# ── AI Provider (choose one) ──────────────────────────────────────────────────
# RC Insights uses litellm, so any supported provider works.
# Without any key, it falls back to heuristic analysis automatically.

# OpenAI (default model: gpt-4o-mini)
# OPENAI_API_KEY=sk-your-openai-key-here

# Anthropic Claude
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Groq (very fast inference, generous free tier)
# GROQ_API_KEY=gsk_your-groq-key-here

# Mistral AI
# MISTRAL_API_KEY=your-mistral-key-here

# Ollama (local, completely free — just run `ollama serve`)
# No key needed. Use: rc-insights report --model ollama/llama3

# Universal key override (takes precedence over provider-specific vars above)
# LLM_API_KEY=your-key-here
